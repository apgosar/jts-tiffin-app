{
  "name": "jts-tiffin-app",
  "version": "1.0.0",
  "description": "Jain Tiffin Service – Daily tiffin ordering web app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"cd client && npm start\"",
    "build": "cd client && npm run build",
    "gcp-build": "cd client && npm install && npm run build",
    "postinstall": "cd client && npm install",
    "install-all": "npm install && cd client && npm install",
    "sheet:init": "node scripts/init-google-sheet.js",
    "test:api": "cross-env USE_MOCK_DATA=true ADMIN_PASSWORD=changeme jest tests/api --detectOpenHandles --forceExit",
    "test:coverage": "cross-env USE_MOCK_DATA=true ADMIN_PASSWORD=changeme jest tests/api --coverage --detectOpenHandles --forceExit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.0",
    "firebase-admin": "^14.0.0",
    "helmet": "^8.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "playwright": "^1.61.1",
    "supertest": "^7.2.2"
  }
}
