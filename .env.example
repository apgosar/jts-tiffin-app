# Google Sheets Integration
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
SPREADSHEET_ID=your_google_spreadsheet_id_here

# Admin Panel
ADMIN_PASSWORD=changeme

# Server
PORT=5000
NODE_ENV=development

# Your Cloud Run production URL — used for CORS allow-list
# Example: PRODUCTION_DOMAIN=https://jts-tiffin-abc123-uc.a.run.app
PRODUCTION_DOMAIN=

# Set to true to use mock data (no Google Sheets required)
USE_MOCK_DATA=true

# Borivali pincodes (comma-separated). Leave empty = no surcharge for anyone.
# Example: BORIVALI_PINCODES=400066,400067,400068,400092
BORIVALI_PINCODES=

# Outside Borivali delivery surcharge per tiffin box
OUTSIDE_DELIVERY_SURCHARGE=40

# Optional: share the sheet with your personal Gmail after creation
SHEET_SHARE_EMAIL=
